# ── APIs ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# ── Servicios ─────────────────────────────────────────────────────
GOTENBERG_URL=http://localhost:3000
PORT=3005

# ── Configuración de empresa ──────────────────────────────────────
# CIF/NIF de tu empresa (el que aparece como cliente en las facturas)
CIF_EMPRESA=B00000000

# Nombres propios separados por comas (en minúsculas, sin espacios)
# Se usan para detectar facturas emitidas por tu propia empresa → carpeta revisar
# Ejemplo: miempresa,miotranombre,marcacomercial
PROVEEDORES_PROPIOS=miempresa,miotranombre

# Nombre completo para el prompt de IA (como aparece en las facturas)
NOMBRE_EMPRESA_PROMPT=MI EMPRESA SL

# Segunda marca o nombre comercial (opcional)
NOMBRE_EMPRESA_2_PROMPT=MI OTRA MARCA
